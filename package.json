{
  "name": "xombi",
  "version": "2.4.14-alpha.0",
  "description": "An XMTP bot used to handle requests for Ombi",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "npx tsc",
    "start": "node dist/index.js",
    "dev": "npx tsx index.ts",
    "test": "npx jest --config jest.config.cjs --coverage",
    "format": "npx prettier . --write",
    "lint": "npx eslint .",
    "typecheck": "npx tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "github.com/jrh3k5/xombi"
  },
  "keywords": [
    "ombi",
    "xmtp"
  ],
  "author": "Joshua Hyde",
  "license": "Apache-2.0",
  "dependencies": {
    "@types/express": "^5.0.6",
    "@xmtp/node-sdk": "^6.0.0",
    "axios": "^1.15.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "viem": "^2.47.16"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.2.1",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1"
  }
}
